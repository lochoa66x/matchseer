# MatchSeer environment template
# Copy to .env.local for local development. Do not commit real secrets.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Neon Postgres
DATABASE_URL=

# App
NEXT_PUBLIC_APP_NAME=MatchSeer
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Future data providers
FOOTBALL_DATA_API_TOKEN=
FOOTBALL_DATA_COMPETITION=WC
MATCHSEER_SYNC_SECRET=
# Open-Meteo weather sync is keyless for the current venue-weather bridge.
