# MatchSeer environment template
# Copy to .env.local for local development. Do not commit real secrets.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Neon Postgres
DATABASE_URL=

# App
NEXT_PUBLIC_APP_NAME=MatchSeer
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Future data providers
FOOTBALL_DATA_API_TOKEN=
FOOTBALL_DATA_COMPETITION=WC
MATCHSEER_SYNC_SECRET=
# Open-Meteo weather sync is keyless for the current venue-weather bridge.

# NFL Lab
# Defaults to the keyless ESPN NFL scoreboard feed when unset.
NFL_SEER_DATA_URL=
# Optional canonical fantasy projection JSON feed.
NFL_FANTASY_DATA_URL=
# Optional source-projection JSON feed for source vs Seer receipts.
NFL_FANTASY_PROJECTIONS_URL=
# Optional rankings/ECR/ADP JSON feed; rows can be rankings-only.
NFL_FANTASY_RANKINGS_URL=
# Optional public Sleeper league import for roster-aware player lanes.
NFL_SLEEPER_LEAGUE_ID=
# Optional override when Sleeper's current NFL week differs from the lab week.
NFL_SLEEPER_WEEK=
# Freshness windows for fantasy provider receipts.
NFL_FANTASY_FRESH_HOURS=24
NFL_FANTASY_STALE_HOURS=72
# Public crowd signal; set to 0 to disable.
NFL_POLYMARKET_ENABLED=1
NFL_POLYMARKET_MAX_GAMES=6
NFL_POLYMARKET_MAX_SHIFT=4
NFL_POLYMARKET_MAX_WEIGHT=0.16
